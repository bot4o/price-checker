from loguru import logger

# Write to a file, rotate when it hits 10MB, keep for 7 days
logger.add(
    "logs/scraper.log",
    rotation="10 MB",
    retention="7 days",
    format="{time:YYYY-MM-DD HH:mm:ss} | {level: <7} | {message}",
    level="INFO"
)

# Anywhere in your scraping functions:
logger.info("Starting scrape for: iPhone 15 Battery on bazar.bg")
logger.warning("bazar.bg took 1.2 seconds to respond - slightly slow!")
